{
  "name": "@gamecult/eve-electron",
  "version": "0.1.0",
  "type": "module",
  "description": "Provider-agnostic Electron runtime for Eve surfaces.",
  "license": "MPL-2.0",
  "main": "src/index.mjs",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs"
    },
    "./provider-client": {
      "types": "./src/cultmesh-provider-client.d.ts",
      "import": "./src/cultmesh-provider-client.mjs"
    },
    "./preload": "./src/eve-provider-preload.cjs"
  },
  "files": ["src", "capture", "scripts", "eve-runtime-capability.json", "README.md", "LICENSE"],
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "pack:check": "npm pack --dry-run",
    "capture:conformance": "powershell -ExecutionPolicy Bypass -File scripts/capture-conformance.ps1"
  },
  "devDependencies": {
    "electron": "^42.4.1"
  },
  "peerDependencies": {
    "electron": ">=30"
  },
  "peerDependenciesMeta": {
    "electron": { "optional": true }
  }
}
